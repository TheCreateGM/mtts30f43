;; Moore Threads MTT S30 GPU SELinux Policy
;; Fedora Linux compatible
;;
;; Compile and install:
;;   checkmodule -M -m mtt_s30.te -o mtt_s30.mod
;;   semodule_package -m mtt_s30.mod -o mtt_s30.pp
;;   sudo semodule -i mtt_s30.pp
;;
;; Copyright © 2022-2024 Moore Threads Inc. All rights reserved.

module mtt_s30 1.0.0;

require {
    type unconfined_t;
    type kernel_t;
    type device_t;
    type modules_object_t;
    type firmware_t;
    type var_run_t;
    type udev_t;
    type insmod_t;
    type depmod_t;
    class system { module_request };
    class module { load };
    class file { read write open getattr ioctl create unlink };
    class chr_file { read write open getattr ioctl };
    class dir { read search add_name remove_name };
    class system { module_request };
    class capability { sys_module };
    class process { execmem };
    class firmware { load };
}

;; ── Kernel module loading ──────────────────────────────────────────────
allow insmod_t kernel_t:system module_request;
allow insmod_t kernel_t:module { load };
allow insmod_t modules_object_t:file { read open getattr };
allow insmod_t modules_object_t:dir { read search };

;; ── Mtgpu module loading ───────────────────────────────────────────────
allow depmod_t modules_object_t:file { read open getattr };
allow depmod_t modules_object_t:dir { read search };

;; ── Device node access ─────────────────────────────────────────────────
allow kernel_t device_t:chr_file { read write ioctl };
allow unconfined_t self:capability sys_module;
allow unconfined_t self:process execmem;

;; ── SGpu device nodes (dynamic major/minor) ────────────────────────────
allow unconfined_t device_t:chr_file { read write open getattr ioctl };
allow unconfined_t var_run_t:file { read write open };

;; ── Firmware loading ───────────────────────────────────────────────────
allow kernel_t firmware_t:file { read open getattr mmap };
allow kernel_t firmware_t:dir { read search };
allow kernel_t self:firmware load;

;; ── Proc filesystem interface ─────────────────────────────────────────
allow unconfined_t self:file { read write open };
allow kernel_t kernel_t:file { read write open };

;; ── udev device node creation ─────────────────────────────────────────
allow udev_t device_t:chr_file { create unlink };
allow udev_t device_t:dir { add_name remove_name search };
